NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/voice_ai_interview
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
REDIS_URL=redis://127.0.0.1:6379
ENABLE_REDIS=false
UPLOAD_DIR=uploads
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=250
AUTH_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_MAX=60
MOCK_AI=true
MOCK_STT=true
MOCK_TTS=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
INTERVIEWER_MODEL=gpt-4o-mini
INTERVIEWER_PERSONA=professional
STT_PROVIDER=openai
OPENAI_WHISPER_MODEL=whisper-1
DEEPGRAM_API_KEY=
TTS_MODEL=tts-1
TTS_VOICE=onyx
ELEVENLABS_API_KEY=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="InterviewAI <no-reply@example.com>"
